  "languages": {
    "JSONC": {
      "show_edit_predictions": true,
    },
    "JavaScript": {
      "format_on_save": "off",
    },
    "Shell Script": {
      "format_on_save": "off",
      "tab_size": 4,
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "4"],
        },
      },
    },
    "Python": {
      "language_servers": ["pyrefly", "!pyright", "!pylsp", "!basedpyright"],
      "format_on_save": "off",
      "formatter": [
        {
          "external": {
            "command": "bash",
            "arguments": [
              "-c",
              "ruff check --select I --fix - | ruff format -",
            ],
          },
        },
      ],
    },
    "C++": {
      "tab_size": 2,
    },
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "lsp": {
    "pyrefly": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
        },
        "pyrefly": {
          "project_includes": ["src/**/*.py", "tests/**/*.py"],
          "project_excludes": ["**/.[!/.]*", "**/*venv/**"],
          "search_path": ["src"],
          "ignore_errors_in_generated_code": false,
        },
      },
    },
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "typeCheckingMode": "basic"
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 80,
          "lint": {
            "extendSelect": ["I"],
          },
        },
      },
    },
    "rust-analyzer": {
      "binary": {
        "path": "/usr/lib/rustup/bin/rust-analyzer",
      },
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
        },
        "python": {
          "pythonPath": ".venv/bin/python",
        },
      },
    },
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": true,
            "forwardSearchAfter": true,
          },
          "forwardSearch": {
            "executable": "sioyek",
            "args": [
              "--reuse-window",
              "--inverse-search",
              "zeditor \"%%1\":%%2",
              "--forward-search-file",
              "%f",
              "--forward-search-line",
              "%l",
              "%p",
            ],
          },
        },
      },
    },
  },
  "agent": {
    "enable_feedback": false,
    "expand_edit_card": false,
    "tool_permissions": {
      "default": "allow"
    },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": false,
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "terminal": true,
          "batch_tool": true,
          "code_actions": true,
          "code_symbols": true,
          "contents": true,
          "copy_path": true,
          "create_file": true,
          "delete_path": false,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "rename": true,
          "symbol_info": true,
          "thinking": true,
          "open": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {},
      },
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "oswe-vscode-prime",
      // "model": "grok-code-fast-1"
    },
    "default_profile": "write",
    "dock": "left",
    "default_width": 450,
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
    },
  },
